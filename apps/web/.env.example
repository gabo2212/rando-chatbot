BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Local Postgres + pgvector (Docker Compose)
DATABASE_URL=postgresql://rando:rando@127.0.0.1:5433/rando

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# xAI / Grok — powers the Endless Drive "RANDO Council" NPC one-liners.
# Cheapest model that still rambles funny; batched + pooled server-side so spend stays tiny.
# If XAI_API_KEY is unset, the game silently falls back to its local generator.
XAI_API_KEY=
# Non-reasoning model = no wasted reasoning tokens for chatty nonsense.
XAI_MODEL=grok-4.20-non-reasoning
# Optional: override the council persona. Falls back to a built-in default.
COUNCIL_SYSTEM_PROMPT=

# Local Ollama embeddings (Docker Compose)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_EMBED_MODEL=nomic-embed-text
